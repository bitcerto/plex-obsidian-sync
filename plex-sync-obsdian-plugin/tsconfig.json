{
  "compilerOptions": {
    "baseUrl": ".",
    "inlineSourceMap": true,
    "inlineSources": true,
    "module": "ESNext",
    "target": "ES2018",
    "allowJs": false,
    "noImplicitAny": true,
    "moduleResolution": "Bundler",
    "importHelpers": true,
    "types": ["node", "vitest/globals"],
    "lib": ["DOM", "ES2018"]
  },
  "include": ["src/**/*.ts"]
}
