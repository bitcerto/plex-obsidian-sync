PLEX_BASE_URL=http://192.168.1.10:32400
PLEX_TOKEN=COLE_SEU_X_PLEX_TOKEN

# Caminho absoluto do seu vault
OBSIDIAN_VAULT_DIR=/home/lucas/Obsidian/Vault

# Subpasta no vault onde as notas da biblioteca serao geradas
OBSIDIAN_NOTES_SUBDIR=Media/Plex

# Bibliotecas separadas por virgula. Se vazio, sincroniza todas de video (movie/show)
PLEX_LIBRARIES=Filmes,Series

# Empate quando Plex e Obsidian mudam no mesmo ciclo: plex | obsidian | latest
SYNC_CONFLICT_POLICY=plex

# Intervalo do modo continuo
SYNC_INTERVAL_SECONDS=30

# Opcional: arquivo de estado manual
# SYNC_STATE_FILE=/home/lucas/Obsidian/Vault/Media/Plex/.plex-obsidian-state.json
